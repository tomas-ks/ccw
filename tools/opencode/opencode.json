{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "openai/gpt-5.4",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:26b": {
          "name": "Gemma 4 26B"
        },
        "gemma4:e4b": {
          "name": "Gemma 4 4B"
        },
        "gemma4:e2b": {
          "name": "Gemma 4 2B"
        }
      }
    }
  },
  "permission": {
    "*": "deny",
    "ifc_*": "allow",
    "read": "deny",
    "edit": "deny",
    "glob": "deny",
    "grep": "deny",
    "bash": "deny",
    "task": "deny",
    "skill": "deny",
    "lsp": "deny",
    "question": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
